{
  "name": "zploited/laravel-identity",
  "description": "Laravel package for protecting API routes with Identity.",
  "minimum-stability": "stable",
  "license": "proprietary",
  "authors": [
    {
      "name": "Dennis Nielsen",
      "email": "dni@zploited.dk"
    }
  ],
  "require": {
    "php": "^7.4|^8.0",
    "laravel/framework": "^8.81",
    "lcobucci/jwt": "^4.1",
    "guzzlehttp/guzzle": "^7.4",
    "strobotti/php-jwk": "^1.3",
    "ext-json": "*"
  },
  "require-dev": {
    "orchestra/testbench": "^6.24"
  },
  "autoload": {
    "psr-4": {
      "Zploited\\Laravel\\Identity\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Zploited\\Laravel\\Identity\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Zploited\\Laravel\\Identity\\IdentityServiceProvider"
      ]
    }
  }
}
